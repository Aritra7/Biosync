# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# USDA FoodData Central (optional — raises rate limit from 1000 to 3600 req/hr)
# Get free key at: https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=DEMO_KEY

# Kroger Developer API (OAuth2)
# Get credentials at: https://developer.kroger.com
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# Set to "true" to use mock APIs instead of real ones (for development)
USE_MOCK_APIS=true
